<?xml version="1.0" encoding="utf-8"?>
<configuration>

  <appSettings>
    <!-- Teams webhook: leave empty to disable Teams notifications -->
    <add key="TeamsWebhookUrl" value="" />

    <!-- SMTP — configure for your internal mail relay or SMTP server -->
    <add key="SmtpHost"                   value="smtp.your-company.com" />
    <add key="SmtpPort"                   value="25" />
    <add key="SmtpFrom"                   value="ifix-reset@your-company.com" />
    <add key="SmtpTo"                     value="it-group@your-company.com" />
    <add key="SmtpUseDefaultCredentials"  value="false" />
    <add key="SmtpUser"                   value="" />
    <add key="SmtpPass"                   value="" />
    <add key="SmtpEnableSsl"              value="false" />

    <!-- Log file: absolute path on the server -->
    <add key="LogPath" value="C:\inetpub\wwwroot\ifix-reset-app\reset.log" />
  </appSettings>

  <system.web>
    <!-- Allow uploads up to 10MB -->
    <httpRuntime maxRequestLength="10240" requestValidationMode="2.0" />
    <customErrors mode="Off" />
    <compilation debug="false" targetFramework="4.5">
      <assemblies>
        <add assembly="System.DirectoryServices, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b03f5f7f11d50a3a" />
        <add assembly="System.DirectoryServices.AccountManagement, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" />
      </assemblies>
    </compilation>
  </system.web>

  <system.webServer>
    <validation validateIntegratedModeConfiguration="false" />

    <!-- IIS request size limit (bytes) — 10MB -->
    <security>
      <requestFiltering>
        <requestLimits maxAllowedContentLength="10485760" />
      </requestFiltering>
    </security>

    <!-- MIME types for modern image formats (iPhone/Android camera uploads) -->
    <staticContent>
      <remove fileExtension=".svg" />
      <mimeMap fileExtension=".svg"  mimeType="image/svg+xml" />
      <mimeMap fileExtension=".heic" mimeType="image/heic" />
      <mimeMap fileExtension=".heif" mimeType="image/heif" />
    </staticContent>

  </system.webServer>

</configuration>
